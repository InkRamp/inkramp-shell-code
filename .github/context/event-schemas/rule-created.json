{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Rule Created Event",
  "description": "Event emitted when a new incentive rule is created",
  "type": "object",
  "properties": {
    "event": {
      "type": "string",
      "const": "rule.created",
      "description": "Event type identifier"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "Event timestamp in ISO 8601 format"
    },
    "payload": {
      "type": "object",
      "properties": {
        "ruleId": {
          "type": "string",
          "description": "Unique identifier of the created rule"
        },
        "name": {
          "type": "string",
          "description": "Name of the rule"
        },
        "orgId": {
          "type": "string",
          "description": "Organization the rule belongs to"
        },
        "createdBy": {
          "type": "string",
          "description": "User ID who created the rule"
        },
        "status": {
          "type": "string",
          "enum": ["active", "paused"],
          "description": "Initial status of the rule"
        },
        "effectiveFrom": {
          "type": "string",
          "format": "date-time",
          "description": "When the rule becomes effective"
        }
      },
      "required": ["ruleId", "name", "orgId", "createdBy", "status", "effectiveFrom"]
    }
  },
  "required": ["event", "timestamp", "payload"],
  "examples": [
    {
      "event": "rule.created",
      "timestamp": "2024-01-15T10:30:00Z",
      "payload": {
        "ruleId": "rule-123-abc",
        "name": "Q1 Sales Bonus",
        "orgId": "org-456",
        "createdBy": "user-789",
        "status": "active",
        "effectiveFrom": "2024-01-01T00:00:00Z"
      }
    }
  ]
}
