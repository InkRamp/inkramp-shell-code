{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "i17e Domain Models",
  "description": "Domain model definitions for the i17e Incentive Management System",
  "definitions": {
    "User": {
      "type": "object",
      "description": "User entity with role and organizational context",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique user identifier"
        },
        "name": {
          "type": "string",
          "description": "User's display name"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "User's email address"
        },
        "role": {
          "type": "string",
          "enum": ["super-admin", "org-admin", "team-lead", "sales-executive"],
          "description": "User's role in the system"
        },
        "orgId": {
          "type": "string",
          "description": "Organization the user belongs to"
        },
        "teamId": {
          "type": "string",
          "description": "Team the user belongs to (optional)"
        },
        "managerId": {
          "type": "string",
          "description": "User's manager ID (optional)"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "User creation timestamp"
        }
      },
      "required": ["id", "name", "email", "role"]
    },
    "Organization": {
      "type": "object",
      "description": "Multi-tenant organization entity",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique organization identifier"
        },
        "name": {
          "type": "string",
          "description": "Organization name"
        },
        "settings": {
          "type": "object",
          "description": "Organization-specific settings"
        },
        "status": {
          "type": "string",
          "enum": ["active", "suspended", "archived"],
          "description": "Organization status"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["id", "name", "status"]
    },
    "Team": {
      "type": "object",
      "description": "Team within an organization",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique team identifier"
        },
        "name": {
          "type": "string",
          "description": "Team name"
        },
        "orgId": {
          "type": "string",
          "description": "Parent organization ID"
        },
        "leadId": {
          "type": "string",
          "description": "Team lead user ID"
        },
        "memberIds": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Array of team member user IDs"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["id", "name", "orgId"]
    },
    "Rule": {
      "type": "object",
      "description": "Incentive rule definition",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique rule identifier"
        },
        "name": {
          "type": "string",
          "description": "Rule name"
        },
        "description": {
          "type": "string",
          "description": "Rule description"
        },
        "orgId": {
          "type": "string",
          "description": "Organization this rule belongs to"
        },
        "createdBy": {
          "type": "string",
          "description": "User ID who created the rule"
        },
        "conditions": {
          "type": "array",
          "items": { "$ref": "#/definitions/RuleCondition" },
          "description": "Array of conditions that must be met"
        },
        "actions": {
          "type": "array",
          "items": { "$ref": "#/definitions/RuleAction" },
          "description": "Array of actions to execute when conditions are met"
        },
        "status": {
          "type": "string",
          "enum": ["active", "paused", "archived"],
          "description": "Rule status"
        },
        "effectiveFrom": {
          "type": "string",
          "format": "date-time",
          "description": "Rule effective start date"
        },
        "effectiveTo": {
          "type": "string",
          "format": "date-time",
          "description": "Rule effective end date (optional)"
        },
        "version": {
          "type": "integer",
          "description": "Rule version number for audit tracking"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["id", "name", "orgId", "createdBy", "conditions", "actions", "status", "version"]
    },
    "RuleCondition": {
      "type": "object",
      "description": "Condition within a rule",
      "properties": {
        "field": {
          "type": "string",
          "description": "Field name to evaluate"
        },
        "operator": {
          "type": "string",
          "enum": ["eq", "neq", "gt", "gte", "lt", "lte", "in", "nin", "contains", "startsWith", "endsWith"],
          "description": "Comparison operator"
        },
        "value": {
          "description": "Value to compare against (can be string, number, or array)"
        }
      },
      "required": ["field", "operator", "value"]
    },
    "RuleAction": {
      "type": "object",
      "description": "Action to execute when rule conditions are met",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["bonus", "multiplier", "tier", "notification", "badge"],
          "description": "Type of action"
        },
        "params": {
          "type": "object",
          "description": "Action-specific parameters"
        }
      },
      "required": ["type", "params"]
    },
    "Incentive": {
      "type": "object",
      "description": "Calculated incentive for a user",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique incentive identifier"
        },
        "userId": {
          "type": "string",
          "description": "User who earned the incentive"
        },
        "ruleId": {
          "type": "string",
          "description": "Rule that triggered the incentive"
        },
        "amount": {
          "type": "number",
          "description": "Incentive amount"
        },
        "currency": {
          "type": "string",
          "description": "Currency code (e.g., USD, EUR)"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "approved", "paid", "rejected"],
          "description": "Incentive status"
        },
        "period": {
          "type": "string",
          "description": "Period for this incentive (e.g., 2024-Q1)"
        },
        "calculatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "approvedBy": {
          "type": "string",
          "description": "User ID who approved (if approved)"
        },
        "approvedAt": {
          "type": "string",
          "format": "date-time"
        },
        "paidAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["id", "userId", "ruleId", "amount", "currency", "status", "period", "calculatedAt"]
    },
    "Target": {
      "type": "object",
      "description": "Sales or performance target",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique target identifier"
        },
        "userId": {
          "type": "string",
          "description": "User assigned to this target"
        },
        "type": {
          "type": "string",
          "enum": ["sales", "units", "customers", "custom"],
          "description": "Target type"
        },
        "metric": {
          "type": "string",
          "description": "Metric being measured"
        },
        "targetValue": {
          "type": "number",
          "description": "Target value to achieve"
        },
        "currentValue": {
          "type": "number",
          "description": "Current progress value"
        },
        "percentage": {
          "type": "number",
          "description": "Completion percentage"
        },
        "period": {
          "type": "string",
          "description": "Target period"
        },
        "status": {
          "type": "string",
          "enum": ["active", "completed", "missed"],
          "description": "Target status"
        },
        "dueDate": {
          "type": "string",
          "format": "date-time"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["id", "userId", "type", "metric", "targetValue", "period", "status", "dueDate"]
    }
  }
}
