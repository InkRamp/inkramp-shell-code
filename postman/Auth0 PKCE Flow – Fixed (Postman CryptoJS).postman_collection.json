{
	"info": {
		"_postman_id": "4add6384-c5f7-495c-8fb4-d9b0f00074ab",
		"name": "Auth0 PKCE Flow – Fixed (Postman CryptoJS)",
		"description": "PKCE flow for Auth0 using Postman-compatible PKCE generator (CryptoJS).",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
		"_exporter_id": "40197535"
	},
	"item": [
		{
			"name": "1️⃣ Generate PKCE (Verifier & Challenge) - Fixed",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"// Postman-compatible PKCE generator using CryptoJS",
							"// Generates an 86-character verifier and a base64url-encoded SHA256 challenge.",
							"",
							"function generateVerifier(len) {",
							"  const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789-._~';",
							"  let out = '';",
							"  for (let i = 0; i < len; i++) {",
							"    out += chars[Math.floor(Math.random() * chars.length)];",
							"  }",
							"  return out;",
							"}",
							"",
							"function base64urlEncodeWordArray(wordArray) {",
							"  const base64 = CryptoJS.enc.Base64.stringify(wordArray);",
							"  return base64.replace(/\\+/g, '-').replace(/\\//g, '_').replace(/=+$/, '');",
							"}",
							"",
							"const verifier = generateVerifier(86);",
							"pm.environment.set('code_verifier', verifier);",
							"",
							"// compute SHA256(verifier) -> base64url",
							"const hash = CryptoJS.SHA256(verifier);",
							"const challenge = base64urlEncodeWordArray(hash);",
							"pm.environment.set('code_challenge', challenge);",
							"",
							"console.log('PKCE generated — verifier (keep secret):', verifier);",
							"console.log('PKCE generated — challenge:', challenge);"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "https://postman-echo.com/get",
					"protocol": "https",
					"host": [
						"postman-echo",
						"com"
					],
					"path": [
						"get"
					]
				},
				"description": "Run this to create code_verifier and code_challenge in environment."
			},
			"response": []
		},
		{
			"name": "2️⃣ Open Auth URL (Copy to browser & login)",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"const domain = pm.environment.get('auth0_domain');",
							"const client = pm.environment.get('client_id');",
							"const redirect = encodeURIComponent(pm.environment.get('redirect_uri'));",
							"const scope = encodeURIComponent('openid profile email');",
							"const audience = encodeURIComponent(pm.environment.get('audience'));",
							"const challenge = pm.environment.get('code_challenge');",
							"",
							"if (!domain || !client || !redirect || !challenge) {",
							"  console.log('ERROR: missing required environment variables (auth0_domain, client_id, redirect_uri, code_challenge)');",
							"}",
							"",
							"const authUrl = `${domain}/authorize?response_type=code&client_id=${client}&redirect_uri=${redirect}&scope=${scope}&audience=${audience}&code_challenge=${challenge}&code_challenge_method=S256`;",
							"",
							"pm.environment.set('last_auth_url', authUrl);",
							"console.log('\\n--- OPEN THIS URL IN YOUR BROWSER ---\\n' + authUrl + '\\n--- END URL ---\\n');"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "https://postman-echo.com/get",
					"protocol": "https",
					"host": [
						"postman-echo",
						"com"
					],
					"path": [
						"get"
					]
				},
				"description": "This will print the exact /authorize URL in the Postman Console; open that URL in your browser to login."
			},
			"response": []
		},
		{
			"name": "3️⃣ Exchange Code for Token",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"const code = pm.environment.get('auth_code');",
							"if (!code) {",
							"  console.log('ERROR: auth_code is empty. Paste the code param (from browser redirect) into environment variable auth_code');",
							"}"
						],
						"type": "text/javascript"
					}
				},
				{
					"listen": "test",
					"script": {
						"exec": [
							"try {",
							"  const json = pm.response.json();",
							"  if (json.access_token) {",
							"    pm.environment.set('access_token', json.access_token);",
							"    pm.environment.set('id_token', json.id_token || '');",
							"    console.log('✅ Access token stored in environment variable access_token');",
							"  } else {",
							"    console.log('❌ Token exchange did not return access_token:', json);",
							"  }",
							"} catch (e) {",
							"  console.log('Response parsing error', e);",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/x-www-form-urlencoded"
					}
				],
				"body": {
					"mode": "urlencoded",
					"urlencoded": [
						{
							"key": "grant_type",
							"value": "authorization_code"
						},
						{
							"key": "client_id",
							"value": "{{client_id}}"
						},
						{
							"key": "code",
							"value": "{{auth_code}}"
						},
						{
							"key": "redirect_uri",
							"value": "{{redirect_uri}}"
						},
						{
							"key": "code_verifier",
							"value": "{{code_verifier}}"
						}
					]
				},
				"url": {
					"raw": "{{auth0_domain}}/oauth/token",
					"host": [
						"{{auth0_domain}}"
					],
					"path": [
						"oauth",
						"token"
					]
				},
				"description": "Exchanges the authorization code for access and ID tokens."
			},
			"response": []
		},
		{
			"name": "4️⃣ Get UserInfo",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{access_token}}"
					}
				],
				"url": {
					"raw": "{{auth0_domain}}/userinfo",
					"host": [
						"{{auth0_domain}}"
					],
					"path": [
						"userinfo"
					]
				},
				"description": "Retrieves the user profile using the access token."
			},
			"response": []
		}
	]
}